generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  PLATFORM_OPERATOR
  TENANT_ADMIN
  TENANT_MANAGER
  TENANT_EMPLOYEE
}

enum TenantPack {
  OFFICE
  RETAIL
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum DocumentStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  ARCHIVED
}

model Tenant {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  pack        TenantPack
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  memberships Membership[]
  requests    Request[]
  documents   Document[]
  approvals   Approval[]
  attendance  AttendanceRecord[]
  balances    LeaveBalance[]
}

model User {
  id          String        @id @default(cuid())
  email       String        @unique
  fullName    String
  role        UserRole
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  memberships Membership[]
  requests    Request[]     @relation("RequestAuthor")
  approvals   Approval[]    @relation("ApprovalActor")
  documents   Document[]    @relation("DocumentOwner")
  attendance  AttendanceRecord[]
  balances    LeaveBalance[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  title     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Request {
  id          String        @id @default(cuid())
  tenantId     String
  authorId     String
  title        String
  category     String
  status       RequestStatus @default(DRAFT)
  submittedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author       User          @relation("RequestAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  approvals    Approval[]
}

model Approval {
  id          String   @id @default(cuid())
  tenantId    String
  requestId   String?
  actorId     String
  action      String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request     Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  actor       User     @relation("ApprovalActor", fields: [actorId], references: [id], onDelete: Cascade)
}

model Document {
  id          String         @id @default(cuid())
  tenantId    String
  ownerId     String
  title       String
  status      DocumentStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User           @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  tenantId    String
  userId      String
  workDate    DateTime
  checkInAt   DateTime?
  checkOutAt  DateTime?
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveBalance {
  id           String   @id @default(cuid())
  tenantId      String
  userId        String
  leaveType     String
  totalDays     Float
  usedDays      Float
  remainingDays Float
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
