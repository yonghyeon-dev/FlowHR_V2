generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  PLATFORM_OPERATOR
  TENANT_ADMIN
  TENANT_MANAGER
  TENANT_EMPLOYEE
}

enum TenantPack {
  OFFICE
  RETAIL
}

enum TenantStatus {
  ACTIVE
  TRIAL
  GRACE
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum DocumentStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  ARCHIVED
}

enum ApprovalAction {
  APPROVE
  REJECT
}

enum AuditEventType {
  LOGIN
  TENANT_UPDATE
  REQUEST_SUBMIT
  APPROVAL_APPROVE
  APPROVAL_REJECT
  DOCUMENT_SIGN
  SETTINGS_UPDATE
}

model Tenant {
  id              String             @id @default(cuid())
  slug            String             @unique
  name            String
  pack            TenantPack
  status          TenantStatus       @default(TRIAL)
  enabledFeatures String[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  memberships     Membership[]
  requests        Request[]
  documents       Document[]
  approvals       Approval[]
  attendance      AttendanceRecord[]
  balances        LeaveBalance[]
  settings        SettingsSnapshot[]
  auditLogs       AuditLog[]

  @@index([pack, status])
}

model User {
  id          String             @id @default(cuid())
  email       String             @unique
  authUserId  String?            @unique
  fullName    String
  role        UserRole
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  memberships Membership[]
  requests    Request[]          @relation("RequestAuthor")
  approvals   Approval[]         @relation("ApprovalActor")
  documents   Document[]         @relation("DocumentOwner")
  attendance  AttendanceRecord[]
  balances    LeaveBalance[]
  settings    SettingsSnapshot[] @relation("SettingsUpdatedBy")
  auditLogs   AuditLog[]         @relation("AuditActor")
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  title     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Request {
  id          String        @id @default(cuid())
  tenantId     String
  authorId     String
  title        String
  category     String
  reason       String
  status       RequestStatus @default(DRAFT)
  submittedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author       User          @relation("RequestAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  approvals    Approval[]

  @@index([tenantId, status])
  @@index([authorId])
}

model Approval {
  id          String         @id @default(cuid())
  tenantId    String
  requestId   String?
  actorId     String
  action      ApprovalAction
  createdAt   DateTime       @default(now())
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request     Request?       @relation(fields: [requestId], references: [id], onDelete: SetNull)
  actor       User           @relation("ApprovalActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([requestId])
}

model Document {
  id          String         @id @default(cuid())
  tenantId    String
  ownerId     String
  title       String
  status      DocumentStatus @default(DRAFT)
  signedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User           @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([ownerId])
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  workDate   DateTime
  checkInAt  DateTime?
  checkOutAt DateTime?
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, workDate])
  @@index([tenantId, workDate])
}

model LeaveBalance {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  leaveType     String
  totalDays     Float
  usedDays      Float
  remainingDays Float
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, leaveType])
  @@index([tenantId])
}

model SettingsSnapshot {
  id             String   @id @default(cuid())
  tenantId       String
  companyName    String
  businessNumber String
  timezone       String
  workStart      String
  workEnd        String
  updatedById    String
  updatedAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy      User     @relation("SettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: Cascade)

  @@index([tenantId, updatedAt])
}

model AuditLog {
  id         String         @id @default(cuid())
  tenantId   String?
  actorId    String
  actorRole  UserRole
  eventType  AuditEventType
  message    String
  createdAt  DateTime       @default(now())
  tenant     Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actor      User           @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([eventType, createdAt])
}
